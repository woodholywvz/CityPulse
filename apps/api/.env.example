PROJECT_NAME=CityPulse API
ENVIRONMENT=local
APP_VERSION=0.1.0
API_V1_PREFIX=/api
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://0.0.0.0:3000
DATABASE_URL=postgresql+asyncpg://citypulse:citypulse@localhost:5432/citypulse
REDIS_URL=redis://localhost:6379/0
JWT_SECRET_KEY=change-me-in-production-please-rotate
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
OPENAI_API_KEY=
OPENAI_API_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5.4-mini
OPENAI_TIMEOUT_SECONDS=20
OPENAI_MAX_RETRIES=2
S3_ENDPOINT_URL=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=us-east-1
S3_BUCKET=citypulse-local
REQUEST_ID_HEADER=X-Request-ID
DEFAULT_ADMIN_EMAIL=admin@citypulse-demo.com
DEFAULT_ADMIN_PASSWORD=ChangeMe123!
DEFAULT_ADMIN_FULL_NAME=CityPulse Admin
SEED_DEMO_DATA=false
